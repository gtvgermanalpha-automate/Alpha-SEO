# Alpha Digital Solutions — environment variables
# Copy this file to `.env.local` for local development, and set the same keys in
# Vercel (Project → Settings → Environment Variables) for production.
# Without these, the public site builds and runs fine; only the /admin CMS is
# inactive (it shows a "not configured" notice).

# --- Admin login (required for the CMS to accept logins) ---
# The password you type at /admin/login
ADMIN_PASSWORD=

# Any long random string — used to sign the admin session cookie. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# --- Publishing target (required to load & save content) ---
# Token with "Contents: Read and write" on the repository below. RECOMMENDED: a
# GitHub App installation token (auto-refreshing, no expiry) so /admin saves never
# silently break — vs a fine-grained PAT which expires (max 1 year).
GITHUB_TOKEN=

# owner/name of the repository Vercel deploys from
GITHUB_REPO=gtvgermanalpha-automate/Alpha-SEO

# Branch to commit edits to (Vercel auto-deploys its production branch)
GITHUB_BRANCH=main

# ============================================================================
# CONTACT + AUDIT FORMS (optional override)
# The public forms post directly to Formspree — no backend, no database. See FORMS.md.
# ============================================================================

# Your Formspree form endpoint (https://formspree.io → your form → integration).
# Leave blank to use the project's existing form. ⚠ Confirm the endpoint is yours
# before going live — submissions go wherever it points. NEXT_PUBLIC_* values are
# baked in at build time, so changing this needs a redeploy.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
