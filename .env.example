# Alpha Digital Solutions — environment variables
# Copy this file to `.env.local` for local development, and set the same keys in
# Netlify (Site configuration → Environment variables) for production.
# Without these, the public site builds and runs fine; only the /admin CMS is
# inactive (it shows a "not configured" notice).

# --- Admin login (required for the CMS to accept logins) ---
# The password the client types at /admin/login
ADMIN_PASSWORD=

# Any long random string — used to sign the admin session cookie. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# --- Publishing target (required to load & save content) ---
# Token with "Contents: Read and write" on the repository below. RECOMMENDED: a
# GitHub App installation token (auto-refreshing, no expiry) so /admin saves never
# silently break — vs a fine-grained PAT which expires (max 1 year).
GITHUB_TOKEN=

# owner/name of the repository Netlify deploys from
GITHUB_REPO=gtvgermanalpha-automate/Alpha-SEO

# Branch to commit edits to (Netlify auto-deploys from this branch)
GITHUB_BRANCH=main

# ============================================================================
# CONTACT FORM (all optional — the form works without any of these)
# Submissions are captured by Netlify Forms automatically; getting them emailed
# to you is a one-time dashboard setting (no env var). Full guide: FORMS.md.
# ============================================================================

# --- reCAPTCHA v2 (anti-spam) ---
# Google reCAPTCHA v2 "I'm not a robot" keys: https://www.google.com/recaptcha/admin
# Leave blank to keep just the honeypot. To activate: set all three below AND add
# data-netlify-recaptcha="true" to public/__forms.html, then redeploy.
# Site key and SITE_RECAPTCHA_KEY are the SAME value (one is exposed to the
# browser to draw the widget, the other tells Netlify which key to validate against).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
SITE_RECAPTCHA_KEY=
SITE_RECAPTCHA_SECRET=

# --- Visitor auto-reply (confirmation email back to whoever submits the form) ---
# Resend API key (https://resend.com). Leave blank to disable — nothing breaks.
RESEND_API_KEY=
# Verified sender (needs a domain verified in Resend); until set, a shared test
# sender is used so you can trial it. Reply-to is where the visitor's reply lands.
AUTOREPLY_FROM=Alpha Digital Solutions <hello@alphadigitalsol.com>
AUTOREPLY_REPLY_TO=contact@alphadigitalsol.com
# Optional: silently copy the team on every auto-reply.
# AUTOREPLY_BCC=contact@alphadigitalsol.com
